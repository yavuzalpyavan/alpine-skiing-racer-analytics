                    }
                }

                if (Date.now() < tvFreezeUntil) {
                    document.getElementById('tv-clock').textContent = tvFrozenTimeString;
                    if(tvFrozenDiffString && tvFrozenDiffString !== "---") {
                        diffBox.textContent = tvFrozenDiffString;
                        let val = parseFloat(tvFrozenDiffString.replace('+', ''));
                        diffBox.style.backgroundColor = val === 0 ? '#555' : (tvFrozenDiffString.startsWith('-') ? '#2ecc71' : '#e74c3c');
                        diffBox.classList.add('show');
                    }
                } else {
                    const mainTimer = document.getElementById('currentTimer');
                    if (mainTimer) document.getElementById('tv-clock').textContent = mainTimer.textContent;
                    diffBox.classList.remove('show');
                }

                let targetBox = document.getElementById('tv-target-box');
                let showTarget = false;
                if (isTimerRunning) {
                    let myRecs = tvRacer.kayitlar ? tvRacer.kayitlar.filter(r => parseInt(r.tur) === turn) : [];
                    let passedGates = myRecs.length; 
                    let targetMs = getTargetTimeForNextGate(turn, passedGates);
                    
                    if (targetMs) {
                        let currentMs = Date.now() - localStartTimeRef;
                        let timeToTarget = targetMs - currentMs;
                        if (timeToTarget <= 3000) {
                            targetBox.textContent = "HEDEF: " + formatMsToTime(targetMs); 
                            targetBox.style.opacity = '1';
                            showTarget = true;
                        }
                    }
                }
                if (!showTarget && targetBox) targetBox.style.opacity = '0';
            } 
            else {
                tvOverlay.classList.remove('show');
                tvSidebar.classList.remove('show');
            }
        }, 50);
        
    </script>
</body>
</html>
