    <div class="main-content">
        <h1>Alp Disiplini Kronometre</h1>
        <div style="margin-bottom: 20px; display:flex; justify-content:center; gap:10px;">
            <input type="text" id="newRacerName" placeholder="├Ψrn: M. Shiffrin (USA)" style="padding:10px; width: 200px;">
            <input type="text" id="newRacerDesc" placeholder="A├π─▒klama (Opsiyonel)" style="padding:10px; width: 200px;">
            <button onclick="addRacer()">Yar─▒┼θmac─▒ Ekle</button>
            <button onclick="resetAll(this)" style="background:#666; color:white; transition: 0.3s;">Reset</button>
        </div>
        <hr>
        <div id="controlPanel">
            <select id="racerSelect" class="racer-select" style="padding:10px; font-size:1.1em;"></select>
            <br><br>
            <button class="btn-start" onpointerdown="sendStartSignal(1)">1. Tur Ba┼θlat</button>
            <button class="btn-turn" id="btnTurn" onpointerdown="recordTurn()">D├ΨN├ε┼η (TURN)</button>
