        function getFlagEmoji(countryCode) {
            const flags = { 'TUR':'ΏθΘ╣ΏθΘ╖', 'USA':'ΏθΘ║ΏθΘ╕', 'AUT':'ΏθΘοΏθΘ╣', 'SUI':'ΏθΘρΏθΘφ', 'ITA':'ΏθΘχΏθΘ╣', 'FRA':'ΏθΘτΏθΘ╖', 'GER':'ΏθΘσΏθΘς', 'NOR':'ΏθΘ│ΏθΘ┤', 'CAN':'ΏθΘρΏθΘο', 'SWE':'ΏθΘ╕ΏθΘς', 'SLO':'ΏθΘ╕ΏθΘχ', 'CRO':'ΏθΘφΏθΘ╖' };
            return flags[countryCode.toUpperCase()] || countryCode;
        }
        function parseRacerName(fullName) {
            let match = fullName.match(/\((.*?)\)/);
