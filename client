                    <button onclick="downloadResultsPDF()" style="flex:1; background:#c0392b; color:white; padding: 12px; font-weight:bold; border-radius:8px; border:none; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">ΏθΥΕ PDF ─░ND─░R</button>
                    <button onclick="downloadResultsCSV()" style="flex:1; background:#27ae60; color:white; padding: 12px; font-weight:bold; border-radius:8px; border:none; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">ΏθΥΛ CSV ─░ND─░R</button>
