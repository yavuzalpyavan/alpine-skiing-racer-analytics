        function getTargetTimeForNextGate(currentTurn, passedGates) {
            let targetGate = "";
            if (passedGates === 0) targetGate = 'Kap─▒ 1';
            else if (passedGates === 1) targetGate = 'Kap─▒ 2';
            else if (passedGates === 2) targetGate = 'Biti┼θ';
            else return null;

            let leaderRacer = null;
            let allVals = Object.values(allRacers);

            // 1. ADIM: Mevcut Lideri Bul (Tur 1 veya Tur 2'yi bitiren en h─▒zl─▒ ki┼θi)
            if (currentTurn === 1) {
                let bitirenler = allVals.filter(r => r.tablo_1_bilgi && r.tablo_1_bilgi.sure && r.tablo_1_bilgi.sure !== '---' && r.tablo_1_bilgi.sure !== '00:00.00');
                if (bitirenler.length > 0) {
                    bitirenler.sort((a,b) => parseTimeStr(a.tablo_1_bilgi.sure) - parseTimeStr(b.tablo_1_bilgi.sure));
                    leaderRacer = bitirenler[0]; // 1. Turun Genel Lideri
                }
            } else if (currentTurn === 2) {
                let bitirenler = allVals.filter(r => r.tablo_2_bilgi && r.tablo_2_bilgi.sure && r.tablo_2_bilgi.sure !== '---' && r.tablo_2_bilgi.sure !== '00:00.00');
                if (bitirenler.length > 0) {
                    bitirenler.sort((a,b) => parseTimeStr(a.tablo_2_bilgi.sure) - parseTimeStr(b.tablo_2_bilgi.sure));
                    leaderRacer = bitirenler[0]; // 2. Turun (Yar─▒┼θ─▒n) Genel Lideri
                }
            }

            // 2. ADIM: E─θer lider koltu─θunda biri varsa, KES─░NL─░KLE liderin o kap─▒daki s├╝resini hedef olarak d├╢n!
            if (leaderRacer && leaderRacer.kayitlar) {
                let rec = leaderRacer.kayitlar.find(k => parseInt(k.tur) === currentTurn && k.etiket === targetGate);
                if (rec && rec.sure && rec.sure !== '---') {
                    return parseTimeStr(rec.sure) * 1000;
                }
            }

            // 3. ADIM: E─θer yar─▒┼θ yeni ba┼θlad─▒ysa ve hen├╝z biti┼θ ├πizgisini ge├πen (lider) kimse yoksa, 
            // o zaman mecburen o an o kap─▒dan ge├πen en iyi s├╝reyi hedef olarak baz al.
            let bestMs = 99999999;
            allVals.forEach(r => {
                if (r.kayitlar) {
                    let rec = r.kayitlar.find(k => parseInt(k.tur) === currentTurn && k.etiket === targetGate);
                    if (rec && rec.sure && rec.sure !== '---') {
                        let ms = parseTimeStr(rec.sure) * 1000;
                        if (ms < bestMs) bestMs = ms;
                    }
                }
            });
            return bestMs === 99999999 ? null : bestMs;
        }

