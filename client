        function sendStartSignal(t) { 
            if(activeRacerId){
                let startMs = Date.now();
                
                // 1. Sadece "Kronometreyi Ba┼θlat" emrini g├╢nderiyoruz.
                sendMessage(t===1?'start_signal':'start_signal_tur_2', {yarismaci_id: activeRacerId}); 
                
                // 2. SUNUCUYU BEKLEME: Kronometreyi an─▒nda yerel olarak ba┼θlat!
                let offsetMs = 0;
                let r = allRacers[activeRacerId];
                if (t === 2 && r && r.tablo_1_bilgi && r.tablo_1_bilgi.sure && r.tablo_1_bilgi.sure !== '---') {
                    let t1Ms = Math.round(parseTimeStr(r.tablo_1_bilgi.sure) * 1000);
                    if (t1Ms < 999999900) offsetMs = t1Ms;
                }
                
                localStartTimeRef = startMs - offsetMs;
                startSmoothTimer();
                
                // YEN─░: ├Θubu─θu s─▒f─▒rlarken ka├π─▒nc─▒ turu ba┼θlatt─▒─θ─▒m─▒z─▒ (t) zorla i├πine at─▒yoruz!
                resetTurnBar(t);
            } 
        }
        function sendSignal(g) { 
            if(activeRacerId) {
                let clientMs = isTimerRunning ? (Date.now() - localStartTimeRef) : null;
                
                // YEN─░: ├Θifte Say─▒m (Double Counting) Korumas─▒
                // E─θer 2. turdaysak, toplam s├╝reden 1. tur s├╝resini ├π─▒kar─▒p sadece "net s├╝reyi" g├╢nder
                let r = allRacers[activeRacerId];
                if (clientMs !== null && r && parseInt(r.aktif_tur) === 2) {
                    let t1Ms = Math.round(parseTimeStr(r.tablo_1_bilgi?.sure) * 1000);
                    if (t1Ms < 999999990) {
                        clientMs = Math.max(0, clientMs - t1Ms);
                    }
                }
                
                let payload = {yarismaci_id: activeRacerId, gate: g};
                if (clientMs !== null) payload.client_time = clientMs / 1000.0;
                
                sendMessage('lap_signal', payload); 
            } 
        }

