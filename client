    <script>
        const WS_URL = "ws://192.168.1.82:8765"; // L├εTFEN IP'Y─░ KONTROL ET
        let socket;
        let allRacers = {};
        let activeRacerId = null;

        let animationFrameId;
        let localStartTimeRef = 0;
        let isTimerRunning = false;
        let lastServerDiff = "---"; 
        let lastServerDiffVal = 0.0;
        let lastServerRef = "";     

        let currentTurnCount = 0;
        let totalTurns = 40; 
        let referenceTurnTimes = []; 
        let currentRunTurnTimes = [];
        let lastGapToLeader = 0.0;
        let turnColors = [];

        let tvTurnColors = [];
        let referenceRun1TimeMs = 0;

        let gate1Turn = 10;
        let gate2Turn = 20;
        let finishTurn = 40;

        window.globalTvOverallRank = "-";
        window.globalTvRun2Rank = "-";

        // YEN─░: COMBO (STREAK) HAFIZASI
        let streakType = 'none'; 
        let streakCount = 0;
        let streakStartTurn = 0;
        let streakStartGap = 0.0;

        function connectWebSocket() {
            socket = new WebSocket(WS_URL);
            socket.onopen = () => console.log("Sunucuya ba─θland─▒.");
            socket.onmessage = (event) => {
                const data = JSON.parse(event.data);
                
                if (data.action === 'sync_racer' && data.id) {
                    if (activeRacerId !== data.id) {
                        activeRacerId = data.id;
                        const selectEl = document.getElementById('racerSelect');
                        if (selectEl) selectEl.value = activeRacerId;
                        stopSmoothTimer(); resetTurnBar(); updateSelectedRacerInfo();
                    }
                }

                if (data.tip === 'sync_bar') {
                    if (activeRacerId === data.r) {
                        tvTurnColors.push(data.c);
                        updateTVTrackGradient();
                        let dot = document.getElementById('tv-bar-dot');
                        if (dot) {
                            dot.style.top = data.p + '%';
                            dot.style.opacity = '1';
                            dot.style.backgroundColor = data.c; 
                        }
                    }
                }

                // YEN─░: COMBO (SER─░) S─░NYAL─░ GELD─░─η─░NDE
                if (data.tip === 'sync_streak') {
                    if (activeRacerId === data.r) {
                        showStreakBracket(data.t, data.val, data.sP, data.eP);
                    }
                }
                
                if (data.tip === 'yarismaci_listesi_guncelleme') {
                    updateRacerList(data.yarismacilar);
                    updateLeaderboards(data.yarismacilar, data.ikinci_tur_sirasi);
                    
                    const activeRacer = data.yarismacilar.find(r => r.id === activeRacerId);
                    if (!activeRacer || activeRacer.durum !== 'AKTIF') {
                        stopSmoothTimer();
                        if(activeRacer) updateSelectedRacerInfo(); 
                    } 
                } else if (data.tip === 'coklu_zaman_guncelleme') {
                    syncTimerWithServer(data.aktif_yarismacilar);
                }
            };
            socket.onclose = () => setTimeout(connectWebSocket, 5000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            connectWebSocket();
            document.getElementById('totalTurnsInput').addEventListener('change', (e) => { totalTurns = parseInt(e.target.value) || 40; drawTrackMarkers(); });
            document.getElementById('gate1Trigger').addEventListener('change', (e) => { gate1Turn = parseInt(e.target.value); drawTrackMarkers(); });
            document.getElementById('gate2Trigger').addEventListener('change', (e) => { gate2Turn = parseInt(e.target.value); drawTrackMarkers(); });
            document.getElementById('finishTrigger').addEventListener('change', (e) => {
                finishTurn = parseInt(e.target.value);
                document.getElementById('totalTurnsInput').value = finishTurn;
                totalTurns = finishTurn;
                drawTrackMarkers();
            });
            updateModeDisplay();
            drawTrackMarkers(); 
        });

        function drawTrackMarkers() {
            const container = document.getElementById('trackMarkers');
            if(!container) return;
            container.innerHTML = ''; 
            const p1 = (gate1Turn / totalTurns) * 100; const p2 = (gate2Turn / totalTurns) * 100; const p01 = p1 / 2;
            container.innerHTML += `<div id="marker-sector-01" class="sector-delta" style="top: ${p01}%;"></div>`;
            container.innerHTML += `<div class="gate-marker" style="top: ${p1}%;"></div><div class="gate-label" style="top: ${p1}%;">K1</div><div id="marker-delta-k1" class="gate-delta" style="top: ${p1}%; display:none;"></div>`;
            const p12 = (p1 + p2) / 2;
            container.innerHTML += `<div id="marker-sector-12" class="sector-delta" style="top: ${p12}%;"></div>`;
            container.innerHTML += `<div class="gate-marker" style="top: ${p2}%;"></div><div class="gate-label" style="top: ${p2}%;">K2</div><div id="marker-delta-k2" class="gate-delta" style="top: ${p2}%; display:none;"></div>`;

            let tvK1 = document.getElementById('tv-marker-k1');
            let tvK2 = document.getElementById('tv-marker-k2');
            if(tvK1) { tvK1.style.top = p1 + '%'; tvK1.style.display = 'block'; }
            if(tvK2) { tvK2.style.top = p2 + '%'; tvK2.style.display = 'block'; }
        }

        function getTurnColor(delta) {
            if (delta <= -0.07) return "#1B4C00"; if (delta <= -0.06) return "#3EAD01"; if (delta <= -0.05) return "#47C700";
            if (delta <= -0.04) return "#5BFF00"; if (delta <= -0.03) return "#9BFF00"; if (delta <= -0.01) return "#C7FF00"; 
            if (Math.abs(delta) < 0.005) return "#FFFF00"; 
            if (delta <= 0.025) return "#FFED00"; if (delta <= 0.035) return "#FFD900"; if (delta <= 0.045) return "#FFA900"; 
            if (delta <= 0.055) return "#FF6000"; if (delta <= 0.065) return "#FF0000"; if (delta <= 0.075) return "#BD0000"; 
            return "#800000"; 
        }

        function updateTrackGradient() {
            const trackSegments = document.getElementById('trackSegments');
            const count = turnColors.length;
            if (count === 0) { trackSegments.style.background = 'transparent'; return; }
            const smoothness = 0.5; let gradientStr = 'linear-gradient(to bottom, ';
            turnColors.forEach((color, index) => {
                let idealStart = (index / totalTurns) * 100; let idealEnd = ((index + 1) / totalTurns) * 100;
                let drawStart = (index === 0) ? idealStart : idealStart + smoothness; let drawEnd = idealEnd - smoothness;
                gradientStr += `${color} ${drawStart}%, ${color} ${drawEnd}%`;
                if (index < count - 1) gradientStr += ', ';
            });
            let filledPct = (count / totalTurns) * 100;
            if (filledPct < 100) { gradientStr += `, transparent ${filledPct + smoothness}%, transparent 100%`; }
            gradientStr += ')'; trackSegments.style.background = gradientStr;
        }

        function updateTVTrackGradient() {
            const trackSegments = document.getElementById('tv-track-segments');
            if (!trackSegments) return;
            const count = tvTurnColors.length;
            if (count === 0) { trackSegments.style.background = 'transparent'; return; }
            const smoothness = 0.5; let gradientStr = 'linear-gradient(to bottom, ';
            tvTurnColors.forEach((color, index) => {
                let idealStart = (index / totalTurns) * 100; let idealEnd = ((index + 1) / totalTurns) * 100;
                let drawStart = (index === 0) ? idealStart : idealStart + smoothness; let drawEnd = idealEnd - smoothness;
                gradientStr += `${color} ${drawStart}%, ${color} ${drawEnd}%`;
                if (index < count - 1) gradientStr += ', ';
            });
            let filledPct = (count / totalTurns) * 100;
            if (filledPct < 100) { gradientStr += `, transparent ${filledPct + smoothness}%, transparent 100%`; }
            gradientStr += ')'; trackSegments.style.background = gradientStr;
        }

       function recordTurn() {
            if (!isTimerRunning) return;
            currentTurnCount++; if (currentTurnCount === 1) window.recentDeltas = [];

            if (currentTurnCount === gate1Turn) sendSignal('Kap─▒ 1');
            else if (currentTurnCount === gate2Turn) sendSignal('Kap─▒ 2');
            else if (currentTurnCount === finishTurn) sendFinishSignal();

            const currentRunTimeMs = Date.now() - localStartTimeRef;
            currentRunTurnTimes.push(currentRunTimeMs);
            const turnIndex = currentTurnCount - 1; let deltaOfDelta = 0.0; let totalGap = 0.0; let isReferenceRun = false;

            if (referenceTurnTimes.length <= turnIndex) { isReferenceRun = true; } 
            else { 
                isReferenceRun = false; 
                const leaderTimeMs = referenceTurnTimes[turnIndex]; 
                totalGap = (currentRunTimeMs - leaderTimeMs) / 1000.0; 
                deltaOfDelta = totalGap - lastGapToLeader; 
                lastGapToLeader = totalGap; 
            }

            const indicator = document.getElementById('turnIndicator'); const turnNum = document.getElementById('turnNumberDisplay');
            let percentage = (currentTurnCount / totalTurns) * 100; if (percentage > 100) percentage = 100;
            indicator.style.top = percentage + "%";

            let finalColor = "#eeeeee";
            let avgDelta = 0;
            if (isReferenceRun) { 
                indicator.style.backgroundColor = "#fff"; turnColors.push("#eeeeee"); 
            } else {
                window.recentDeltas.push(deltaOfDelta);
                if (window.recentDeltas.length > 3) window.recentDeltas.shift(); 
                avgDelta = Math.round(window.recentDeltas.reduce((a, b) => a + b, 0) / window.recentDeltas.length * 100) / 100;
                finalColor = getTurnColor(avgDelta); 
                indicator.style.backgroundColor = finalColor; turnColors.push(finalColor);
            }
            updateTrackGradient(); turnNum.textContent = currentTurnCount;

            let tvDot = document.getElementById('tv-bar-dot');
            if(tvDot) { tvDot.style.top = percentage + '%'; tvDot.style.backgroundColor = finalColor; }

            sendMessage('sync_bar', { p: percentage, c: finalColor, t: currentTurnCount, r: activeRacerId });

            // --- YEN─░: COMBO (NABIZ + PARANTEZ) ALGOR─░TMASI ---
            if (!isReferenceRun) {
                let currentType = 'none';
                if (avgDelta <= -0.06) currentType = 'gain';
                else if (avgDelta >= 0.06) currentType = 'loss';

                let currentGap = totalGap;

                if (currentType === streakType && currentType !== 'none') {
                    streakCount++;
                    // Nab─▒z: Her 3 d├╢n├╝┼θte bir (3, 6, 9...) ekrana SADECE son 3 d├╢n├╝┼θl├╝k parantezi yans─▒t!
                    if (streakCount >= 3 && streakCount % 3 === 0) {
                        
                        // D├εZELTME 1: Form├╝l d├╝zeltildi (Art─▒k o 3 d├╢n├╝┼θ├╝n net fark─▒n─▒ eksiksiz al─▒yor)
                        let diff = currentGap - streakStartGap; 
                        
                        let startPct = ((currentTurnCount - 3) / totalTurns) * 100; 
                        let endPct = (currentTurnCount / totalTurns) * 100;
                        sendMessage('sync_streak', { t: streakType, val: diff.toFixed(2), sP: startPct, eP: endPct, r: activeRacerId });
                        
                        // D├εZELTME 2: Dilimleme Mant─▒─θ─▒! Sonraki 3'l├╝ hesaplama i├πin ba┼θlang─▒├π noktas─▒n─▒ "┼θu an" olarak g├╝ncelle
                        streakStartGap = currentGap;
                    }
                } else {
                    // Seri k─▒r─▒ld─▒
                    streakType = currentType;
                    if (currentType !== 'none') {
                        streakCount = 1;
                        streakStartTurn = currentTurnCount;
                        streakStartGap = currentGap - deltaOfDelta; 
                    } else {
                        streakCount = 0;
                    }
                }
            }
        }

        function resetTurnBar(forceTurn = null) {
            currentTurnCount = 0; 
            currentRunTurnTimes = []; 
            turnColors = []; 
            
            // Streak S─▒f─▒rlamas─▒
            streakType = 'none';
            streakCount = 0;
            streakStartTurn = 0;
            streakStartGap = 0.0;

            let startingGap = 0.0;
            let r = allRacers[activeRacerId];
            
            // YEN─░: Sunucudan cevab─▒ beklemeden, bizim butondan g├╢nderdi─θimiz turu zorla kabul et!
            let currentTurn = forceTurn || (r ? parseInt(r.aktif_tur) : 1);

            if (r && currentTurn === 2 && referenceTurnTimes.length > 0 && typeof referenceRun1TimeMs !== 'undefined' && referenceRun1TimeMs > 0) {
                let myRun1 = Math.round(parseTimeStr(r.tablo_1_bilgi?.sure) * 100);
                if (myRun1 < 99999999) {
                    startingGap = (myRun1 - Math.round(referenceRun1TimeMs * 100)) / 100.0;
                }
            }
            lastGapToLeader = startingGap;
            
            const indicator = document.getElementById('turnIndicator'); const bubble = document.getElementById('deltaBubble');
            indicator.style.top = "0%"; indicator.style.backgroundColor = "#444";
            document.getElementById('turnNumberDisplay').textContent = "0"; if(bubble) bubble.style.opacity = "0";
            updateTrackGradient(); 

            let tvDot = document.getElementById('tv-bar-dot');
            if(tvDot) { tvDot.style.top = '0%'; tvDot.style.opacity = '0'; tvDot.style.backgroundColor = '#444'; }
        }

        let refConfirmTimeout;
        function setLastRunAsReference(btn) {
            if (currentRunTurnTimes.length === 0) { const oldText = btn.textContent; btn.textContent = "έγιΎ╕Π VER─░ YOK!"; btn.style.backgroundColor = "#e74c3c"; setTimeout(() => { btn.textContent = oldText; btn.style.backgroundColor = "#2ecc71"; }, 2000); return; }
            if (btn.dataset.confirming === "true") {
                referenceTurnTimes = [...currentRunTurnTimes]; 
                
                let r = allRacers[activeRacerId];
                if (r && parseInt(r.aktif_tur) === 2 && r.tablo_1_bilgi && r.tablo_1_bilgi.sure && r.tablo_1_bilgi.sure !== '---') {
                    referenceRun1TimeMs = parseTimeStr(r.tablo_1_bilgi.sure);
                } else {
                    referenceRun1TimeMs = 0;
                }
                
                updateModeDisplay(); clearTimeout(refConfirmTimeout);
                btn.dataset.confirming = "false"; btn.textContent = "έεΖ REFERANS G├εNCELLEND─░!"; btn.style.backgroundColor = "#28a745";
                setTimeout(() => { btn.textContent = "ΏθΠΒ SON YARI┼η├ΘIYI REFERANS YAP"; btn.style.backgroundColor = "#2ecc71"; }, 2000);
            } else {
                btn.dataset.confirming = "true"; btn.textContent = "EM─░N M─░S─░N? (ONAY ─░├Θ─░N TEKRAR BAS)"; btn.style.backgroundColor = "#e74c3c";
                refConfirmTimeout = setTimeout(() => { btn.dataset.confirming = "false"; btn.textContent = "ΏθΠΒ SON YARI┼η├ΘIYI REFERANS YAP"; btn.style.backgroundColor = "#2ecc71"; }, 3000);
            }
        }

        let delRefTimeout;
        function resetReferenceData(btn) {
            if (btn.dataset.confirming === "true") {
                referenceTurnTimes = []; currentRunTurnTimes = []; referenceRun1TimeMs = 0; resetTurnBar(); updateModeDisplay(); clearTimeout(delRefTimeout);
                btn.dataset.confirming = "false"; btn.textContent = "έεΖ S─░L─░ND─░!"; btn.style.backgroundColor = "#28a745";
                setTimeout(() => { btn.textContent = "Referans Verisini S─░L"; btn.style.backgroundColor = "#e67e22"; }, 2000);
            } else {
                btn.dataset.confirming = "true"; btn.textContent = "S─░L─░NECEK! ONAY ─░├Θ─░N TEKRAR BAS"; btn.style.backgroundColor = "#dc3545";
                delRefTimeout = setTimeout(() => { btn.dataset.confirming = "false"; btn.textContent = "Referans Verisini S─░L"; btn.style.backgroundColor = "#e67e22"; }, 3000);
            }
        }
        
        let resetAllTimeout;
        function resetAll(btn) {
            if (btn.dataset.confirming === "true") {
                sendMessage('reset_all'); btn.dataset.confirming = "false"; btn.textContent = "έεΖ SIFIRLANDI!"; btn.style.backgroundColor = "#28a745";
                window.k1ShownSet = new Set(); window.k2ShownSet = new Set(); window.finishShownSet = new Set();
                setTimeout(() => { btn.textContent = "Reset"; btn.style.backgroundColor = "#666"; }, 2000);
            } else {
                btn.dataset.confirming = "true"; const oldText = btn.textContent; btn.textContent = "EM─░N M─░S─░N? (TEKRAR)"; btn.style.backgroundColor = "#dc3545";
                resetAllTimeout = setTimeout(() => { btn.dataset.confirming = "false"; btn.textContent = oldText; btn.style.backgroundColor = "#666"; }, 3000);
            }
        }
        
        function updateModeDisplay() {
            const disp = document.getElementById('modeDisplay');
            if (referenceTurnTimes.length === 0) { disp.textContent = "MOD: REFERANS (─░lk Kay─▒t)"; disp.style.color = "#e67e22"; } 
            else { disp.textContent = "MOD: KAR┼ηILA┼ηTIRMA"; disp.style.color = "#28a745"; }
        }

        function syncTimerWithServer(activeRacers) {
            const currentRacerData = activeRacers.find(r => r.id === activeRacerId);
            if (currentRacerData) {
                let serverDiffStr = currentRacerData.anlik_fark_str;
                let serverDiffVal = parseFloat(serverDiffStr.replace('+', ''));
                if(isNaN(serverDiffVal)) serverDiffVal = 0.0;
                
                // --- YEN─░: A─η GEC─░KMES─░ TELAF─░S─░ (LATENCY COMPENSATION) ---
                // Python'─▒n saati Wi-Fi gecikmesi kadar (yakla┼θ─▒k 250-300ms) geriden gelir.
                // Bu y├╝zden Python'─▒n hesaplad─▒─θ─▒ canl─▒ fark, sporcuyu 300ms daha h─▒zl─▒ (├╢nde) san─▒r.
                // Burada o gecikmeyi milisaniyesine kadar hesaplay─▒p, ekrandaki canl─▒ fark─▒ an─▒nda d├╝zeltiyoruz.
                let refLabel = currentRacerData.referans_etiket;
                if (isTimerRunning && (refLabel === 'Kap─▒ 1' || refLabel === 'Kap─▒ 2')) {
                    const localElapsedSec = (Date.now() - localStartTimeRef) / 1000.0;
                    const serverElapsedSec = currentRacerData.ham_saniye;
                    const lagSec = localElapsedSec - serverElapsedSec; // Gecikmeyi bul
                    
                    if (lagSec > 0.05 && lagSec < 2.0) { // Gecikme mant─▒kl─▒ s─▒n─▒rlardaysa (50ms - 2sn) d├╝zelt
                        serverDiffVal += lagSec;
                        serverDiffStr = (serverDiffVal > 0 ? '+' : '') + serverDiffVal.toFixed(2);
                    }
                }
                // ------------------------------------------------------------

                lastServerDiff = serverDiffStr;
                lastServerRef = refLabel;
                updateLiveDiffDisplay();

                if (!isTimerRunning) { 
                    const now = Date.now();
                    const serverElapsedMs = currentRacerData.ham_saniye * 1000;
                    localStartTimeRef = now - serverElapsedMs;
                    resetTurnBar(); 
                    startSmoothTimer(); 
                }
            }
        }

        function startSmoothTimer() {
            if (isTimerRunning) return;
            isTimerRunning = true;
            function loop() {
                if (!isTimerRunning) return;
                const now = Date.now();
                const elapsedMs = now - localStartTimeRef;
                document.getElementById('currentTimer').textContent = formatMsToTime(elapsedMs);
                animationFrameId = requestAnimationFrame(loop);
            }
            loop();
        }

        function stopSmoothTimer() { isTimerRunning = false; cancelAnimationFrame(animationFrameId); }

        function formatMsToTime(ms) {
            if (ms < 0) ms = 0;
            const totalCentiseconds = Math.floor(ms / 10);
            const cs = totalCentiseconds % 100;
            const s = Math.floor(totalCentiseconds / 100) % 60;
            const m = Math.floor(totalCentiseconds / 100 / 60);
            return `${pad(m)}:${pad(s)}.${pad(cs)}`;
        }
        function pad(n) { return n.toString().padStart(2, '0'); }
        
        function updateLiveDiffDisplay() {
             const liveEl = document.getElementById('liveDifference');
             const refEl = document.getElementById('referenceLabel');
             let diffClass;
             if (lastServerDiff.startsWith('-')) diffClass = 'diff-negative';
             else if (lastServerDiff === '0.00' || lastServerDiff === '+0.00' || lastServerDiff === '---') diffClass = 'diff-zero';
             else diffClass = 'diff-positive';
             liveEl.className = diffClass; liveEl.textContent = lastServerDiff;
             refEl.textContent = lastServerRef === "BA┼ηLANGI├Θ" ? "BA┼ηLANGI├Θ" : (lastServerRef ? `REF: ${lastServerRef}` : "");
        }
        
        function updateRacerList(racers) {
            const select = document.getElementById('racerSelect');
            const activeRunner = racers.find(r => r.durum === 'AKTIF');
            const forceSelectId = activeRunner ? activeRunner.id : null;
            const currentSelectedId = forceSelectId || activeRacerId || select.value;
            
            select.innerHTML = ''; allRacers = {};
            racers.forEach(r => {
                allRacers[r.id] = r;
                const opt = document.createElement('option');
