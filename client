                <input type="text" id="pdfReportTitle" placeholder="PDF Rapor Ba┼θl─▒─θ─▒ (├Ψrn: T├╝rkiye ┼ηampiyonas─▒ - Slalom)" style="width: 100%; padding: 12px; margin-bottom: 15px; box-sizing: border-box; border-radius: 8px; border: 1px solid #ccc;">
