                <label>Kap─▒ 2: <input type="number" id="gate2Trigger" class="trigger-input" value="20">. D├╢n├╝┼θ</label>
                <label>Biti┼θ: <input type="number" id="finishTrigger" class="trigger-input" value="40">. D├╢n├╝┼θ</label>
